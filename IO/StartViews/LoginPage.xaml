<Page x:Class="IO.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IO"
        
      xmlns:vm="clr-namespace:IO.ViewModels"
      xmlns:helper="clr-namespace:IO.res.utils"
      mc:Ignorable="d" 
     Width="1600" Height="1000"
     
      Title="LoginPage">
    <Page.DataContext>
        <vm:LoginViewModel/>
    </Page.DataContext>
    <Grid>
        <Image Source="\res\img\login.jpg"/>
        <Grid Background="White" Margin="408,283,408,282">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="434.62"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Zaloguj się" HorizontalAlignment="Left" FontSize="35" Foreground="Purple" Height="50" Width="180" Margin="288,70,0,315" Grid.Row="4"/>

            <TextBlock Grid.Row="4" Text="Podaj login" Margin="191,149,-91,267" FontSize="14"/>
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Width="400" Height="20" Margin="0,173,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="4"/>

            <TextBlock Grid.Row="4" Text="Podaj hasło" Margin="191,230,-91,185" FontSize="14"/>
            <PasswordBox Width="400" Height="20" Margin="0,255,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Row="4"
                         helper:PasswordHelper.Attach="True" helper:PasswordHelper.Password="{Binding Password, Mode=TwoWay}" />

            <Button Content="Zarejestruj się" Command="{Binding RegisterCommand}" Foreground="Blue" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="13" FontStyle="Italic" Margin="0,322,0,0" Grid.Row="4"/>
            <Button Content="Zaloguj się" Command="{Binding LoginCommand}" Background="AliceBlue" Width="78" Height="23" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,362,0,0" Grid.Row="4"/>
        </Grid>
    </Grid>
</Page>
